@page "/subscriptions"
@using AlertNotificationSystem.Models
@using AlertNotificationSystem.Services
@inject ApiService ApiService

<PageTitle>Subscriptions - Alert Notification System</PageTitle>

<h3>Subscriptions Management</h3>

<div class="mb-3">
	<button class="btn btn-primary" @onclick="ShowCreateForm">
		<span class="oi oi-plus"></span> Create New Subscription
	</button>
</div>

@if (showForm)
{
	<div class="card mb-3">
		<div class="card-header bg-primary text-white">
			<h5>@(editingSubscription?.Id > 0 ? "Edit Subscription" : "Create New Subscription")</h5>
		</div>
		<div class="card-body">
			<EditForm Model="@currentSubscription" OnValidSubmit="@SaveSubscription">
				<DataAnnotationsValidator />
				<ValidationSummary />

				<div class="mb-3">
					<label class="form-label">User Identifier</label>
					<InputText class="form-control" @bind-Value="currentSubscription.UserIdentifier" placeholder="email@example.com or username" />
				</div>

				<div class="mb-3">
					<label class="form-label">Channel</label>
					<InputSelect class="form-control" @bind-Value="currentSubscription.Channel">
						<option value="">-- Select Channel --</option>
						<option value="@NotificationChannel.Email">Email</option>
						<option value="@NotificationChannel.Slack">Slack</option>
					</InputSelect>
				</div>

				<div class="mb-3">
					<label class="form-label">Destination</label>
					<InputText class="form-control" @bind-Value="currentSubscription.Destination" placeholder="email@example.com or webhook URL" />
					<small class="form-text text-muted">
						For Email: email address. For Slack: webhook URL.
					</small>
				</div>

				<div class="mb-3">
					<label class="form-label">Alert Type Filter (Optional)</label>
					<InputSelect class="form-control" @bind-Value="currentSubscription.AlertTypeFilter">
						<option value="">All Types</option>
						<option value="@AlertType.BreakingNews">Breaking News Only</option>
						<option value="@AlertType.MarketMovement">Market Movement Only</option>
						<option value="@AlertType.NaturalDisaster">Natural Disaster Only</option>
					</InputSelect>
				</div>

				<div class="mb-3 form-check">
					<InputCheckbox class="form-check-input" @bind-Value="currentSubscription.IsActive" />
					<label class="form-check-label">Active</label>
				</div>

				<div class="btn-group">
					<button type="submit" class="btn btn-success">
						<span class="oi oi-check"></span> Save
					</button>
					<button type="button" class="btn btn-secondary" @onclick="CancelEdit">
						<span class="oi oi-x"></span> Cancel
					</button>
				</div>
			</EditForm>
		</div>
	</div>
}

@if (isLoading)
{
	<div class="text-center">
		<div class="spinner-border" role="status">
			<span class="visually-hidden">Loading...</span>
		</div>
	</div>
}
else if (subscriptions != null && subscriptions.Any())
{
	<div class="table-responsive">
		<table class="table table-striped table-hover">
			<thead class="table-dark">
				<tr>
					<th>ID</th>
					<th>User</th>
					<th>Channel</th>
					<th>Destination</th>
					<th>Filter</th>
					<th>Status</th>
					<th>Created At</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var subscription in subscriptions)
				{
					<tr>
						<td>@subscription.Id</td>
						<td>@subscription.UserIdentifier</td>
						<td><span class="badge bg-info">@subscription.Channel</span></td>
						<td>
							@if (subscription.Destination.Length > 40)
							{
								<span title="@subscription.Destination">@subscription.Destination.Substring(0, 40)...</span>
							}
							else
							{
								@subscription.Destination
							}
						</td>
						<td>
							@if (subscription.AlertTypeFilter.HasValue)
							{
								<span class="badge bg-secondary">@subscription.AlertTypeFilter</span>
							}
							else
							{
								<span class="text-muted">All</span>
							}
						</td>
						<td>
							@if (subscription.IsActive)
							{
								<span class="badge bg-success">Active</span>
							}
							else
							{
								<span class="badge bg-secondary">Inactive</span>
							}
						</td>
						<td>@subscription.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
						<td>
							<button class="btn btn-sm btn-primary" @onclick="() => EditSubscription(subscription)">
								<span class="oi oi-pencil"></span>
							</button>
							<button class="btn btn-sm btn-danger" @onclick="() => DeleteSubscription(subscription.Id)">
								<span class="oi oi-trash"></span>
							</button>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}
else
{
	<div class="alert alert-info">
		<strong>No subscriptions found.</strong> Create your first subscription using the button above.
	</div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
	<div class="alert alert-danger mt-3">
		<strong>Error:</strong> @errorMessage
	</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
	<div class="alert alert-success mt-3">
		<strong>Success:</strong> @successMessage
	</div>
}

@code {
	private List<Subscription>? subscriptions;
	private bool isLoading = true;
	private bool showForm = false;
	private Subscription currentSubscription = new Subscription();
	private Subscription? editingSubscription;
	private string? errorMessage;
	private string? successMessage;

	protected override async Task OnInitializedAsync()
	{
		await LoadSubscriptions();
	}

	private async Task LoadSubscriptions()
	{
		isLoading = true;
		errorMessage = null;
		try
		{
			subscriptions = await ApiService.GetSubscriptionsAsync();
		}
		catch (Exception ex)
		{
			errorMessage = $"Failed to load subscriptions: {ex.Message}";
		}
		finally
		{
			isLoading = false;
		}
	}

	private void ShowCreateForm()
	{
		currentSubscription = new Subscription { IsActive = true };
		editingSubscription = null;
		showForm = true;
		errorMessage = null;
		successMessage = null;
	}

	private void EditSubscription(Subscription subscription)
	{
		editingSubscription = subscription;
		currentSubscription = new Subscription
		{
			Id = subscription.Id,
			UserIdentifier = subscription.UserIdentifier,
			Channel = subscription.Channel,
			Destination = subscription.Destination,
			AlertTypeFilter = subscription.AlertTypeFilter,
			IsActive = subscription.IsActive
		};
		showForm = true;
		errorMessage = null;
		successMessage = null;
	}

	private void CancelEdit()
	{
		showForm = false;
		currentSubscription = new Subscription();
		editingSubscription = null;
		errorMessage = null;
		successMessage = null;
	}

	private async Task SaveSubscription()
	{
		errorMessage = null;
		successMessage = null;

		try
		{
			bool success;
			if (editingSubscription?.Id > 0)
			{
				success = await ApiService.UpdateSubscriptionAsync(editingSubscription.Id, currentSubscription);
				successMessage = success ? "Subscription updated successfully!" : null;
			}
			else
			{
				success = await ApiService.CreateSubscriptionAsync(currentSubscription);
				successMessage = success ? "Subscription created successfully!" : null;
			}

			if (success)
			{
				showForm = false;
				await LoadSubscriptions();
			}
			else
			{
				errorMessage = "Failed to save subscription. Please try again.";
			}
		}
		catch (Exception ex)
		{
			errorMessage = $"Error saving subscription: {ex.Message}";
		}
	}

	private async Task DeleteSubscription(int id)
	{
		if (confirm($"Are you sure you want to delete subscription #{id}?"))
		{
			errorMessage = null;
			successMessage = null;

			try
			{
				var success = await ApiService.DeleteSubscriptionAsync(id);
				if (success)
				{
					successMessage = "Subscription deleted successfully!";
					await LoadSubscriptions();
				}
				else
				{
					errorMessage = "Failed to delete subscription.";
				}
			}
			catch (Exception ex)
			{
				errorMessage = $"Error deleting subscription: {ex.Message}";
			}
		}
	}

	private bool confirm(string message)
	{
		// Simple confirmation - in production use JSInterop
		return true;
	}
}
