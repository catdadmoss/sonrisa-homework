@page "/"
@layout MainLayout
@using AlertNotificationSystem.Services
@inject ApiService ApiService

<PageTitle>Dashboard - Alert Notification System</PageTitle>

<h3>Dashboard</h3>

@if (isLoading)
{
	<div class="text-center">
		<div class="spinner-border" role="status">
			<span class="visually-hidden">Loading...</span>
		</div>
	</div>
}
else if (statistics != null)
{
	<div class="row">
		<div class="col-md-3">
			<div class="card text-white bg-primary">
				<div class="card-body">
					<h5 class="card-title">Total Alerts</h5>
					<p class="card-text display-4">@totalAlerts</p>
				</div>
			</div>
		</div>
		<div class="col-md-3">
			<div class="card text-white bg-warning">
				<div class="card-body">
					<h5 class="card-title">Pending</h5>
					<p class="card-text display-4">@pendingAlerts</p>
				</div>
			</div>
		</div>
		<div class="col-md-3">
			<div class="card text-white bg-success">
				<div class="card-body">
					<h5 class="card-title">Sent</h5>
					<p class="card-text display-4">@sentAlerts</p>
				</div>
			</div>
		</div>
		<div class="col-md-3">
			<div class="card text-white bg-danger">
				<div class="card-body">
					<h5 class="card-title">Failed</h5>
					<p class="card-text display-4">@failedAlerts</p>
				</div>
			</div>
		</div>
	</div>

	<div class="row mt-4">
		<div class="col-md-6">
			<div class="card">
				<div class="card-header bg-info text-white">
					<h5>Alerts by Type</h5>
				</div>
				<div class="card-body">
					@if (byType != null && byType.Count > 0)
					{
						<ul class="list-group">
							@foreach (var item in byType)
							{
								<li class="list-group-item d-flex justify-content-between align-items-center">
									@item.Key
									<span class="badge bg-primary rounded-pill">@item.Value</span>
								</li>
							}
						</ul>
					}
					else
					{
						<p>No data available</p>
					}
				</div>
			</div>
		</div>
		<div class="col-md-6">
			<div class="card">
				<div class="card-header bg-secondary text-white">
					<h5>Quick Actions</h5>
				</div>
				<div class="card-body">
					<a href="/alerts" class="btn btn-primary btn-block mb-2 w-100">Create New Alert</a>
					<a href="/subscriptions" class="btn btn-success btn-block mb-2 w-100">Manage Subscriptions</a>
					<a href="/logs" class="btn btn-info btn-block w-100">View Notification Logs</a>
				</div>
			</div>
		</div>
	</div>
}
else
{
	<div class="alert alert-danger">
		<strong>Error loading statistics.</strong> Please check your API connection.
	</div>
}

@code {
	private bool isLoading = true;
	private object? statistics;
	private int totalAlerts;
	private int pendingAlerts;
	private int sentAlerts;
	private int failedAlerts;
	private Dictionary<string, int>? byType;

	protected override async Task OnInitializedAsync()
	{
		await LoadStatistics();
	}

	private async Task LoadStatistics()
	{
		isLoading = true;
		try
		{
			var statsResponse = await ApiService.GetAlertStatisticsAsync();
			if (statsResponse != null)
			{
				statistics = statsResponse;

				// Parse the statistics (assuming structure from API)
				var json = System.Text.Json.JsonSerializer.Serialize(statsResponse);
				var doc = System.Text.Json.JsonDocument.Parse(json);

				if (doc.RootElement.TryGetProperty("totalAlerts", out var total))
					totalAlerts = total.GetInt32();
				if (doc.RootElement.TryGetProperty("pendingAlerts", out var pending))
					pendingAlerts = pending.GetInt32();
				if (doc.RootElement.TryGetProperty("sentAlerts", out var sent))
					sentAlerts = sent.GetInt32();
				if (doc.RootElement.TryGetProperty("failedAlerts", out var failed))
					failedAlerts = failed.GetInt32();

				if (doc.RootElement.TryGetProperty("byType", out var typeStats))
				{
					byType = new Dictionary<string, int>();
					foreach (var prop in typeStats.EnumerateObject())
					{
						byType[prop.Name] = prop.Value.GetInt32();
					}
				}
			}
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Error loading statistics: {ex.Message}");
		}
		finally
		{
			isLoading = false;
		}
	}
}
